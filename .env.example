# ============================================
# IDS-ML Backend Configuration Template
# INSTRUCTIONS: Copy this file to backend/.env
# ============================================

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_TITLE="IDS-ML System API"
API_VERSION="1.0.0"

# Model Configuration
CONFIDENCE_THRESHOLD=0.7
MODEL_PATH=../models/random_forest_ids.pkl
PREPROCESSOR_PATH=../data/processed/preprocessed_data.pkl

# Logging
LOG_LEVEL=INFO
LOG_FILE=../logs/app.log

# CORS (allowed origins - comma separated)
CORS_ORIGINS=http://localhost,http://localhost:3000,http://localhost:8000

# Database Configuration (for future use)
# DATABASE_URL=postgresql://username:password@localhost:5432/database_name

# Security Configuration (for future use)
# SECRET_KEY=generate-a-secret-key
# ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================
# SETUP INSTRUCTIONS:
# 1. Copy this file: cp .env.example backend/.env
# 2. Update values as needed
# 3. Never commit backend/.env to Git
# ============================================
